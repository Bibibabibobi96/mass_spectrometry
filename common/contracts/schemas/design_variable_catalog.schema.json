{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mass-spectrometry.local/schemas/design_variable_catalog.schema.json",
  "title": "Project design variable catalog",
  "oneOf": [
    {"$ref": "#/$defs/oatof_catalog"},
    {"$ref": "#/$defs/multipole_catalog"}
  ],
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$"
    },
    "json_pointer": {
      "type": "string",
      "pattern": "^/(?:[^~/]|~[01])+(?:/(?:[^~/]|~[01])+)*$"
    },
    "rebuild_effects": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"enum": ["theory", "resolved", "comsol", "simion", "spatial_interface", "cad"]}
    },
    "compile_status": {
      "enum": ["declared", "candidate_contract", "solver_synced", "cad_synced"]
    },
    "oatof_catalog": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "role",
        "project_id",
        "optimization_strategy",
        "envelope_contract",
        "range_policy",
        "variables",
        "invariants"
      ],
      "properties": {
        "schema_version": {"const": 1},
        "role": {"const": "project_design_variable_catalog"},
        "project_id": {"const": "oa_tof"},
        "optimization_strategy": {"const": "expandable_reference_envelope_compaction"},
        "envelope_contract": {"type": "string", "minLength": 1},
        "range_policy": {"type": "string", "minLength": 1},
        "variables": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "variable_id",
              "label",
              "kind",
              "optimization_role",
              "json_pointer",
              "unit",
              "minimum",
              "maximum",
              "compile_status",
              "rebuild_effects"
            ],
            "properties": {
              "variable_id": {"$ref": "#/$defs/identifier"},
              "label": {"type": "string", "minLength": 1},
              "kind": {"enum": ["continuous", "integer", "topology", "derived"]},
              "optimization_role": {
                "enum": ["accelerator_bidirectional", "tof_envelope", "tof_internal", "compensation"]
              },
              "json_pointer": {"$ref": "#/$defs/json_pointer"},
              "unit": {"type": "string", "minLength": 1},
              "minimum": {"type": "number"},
              "maximum": {"type": "number"},
              "compile_status": {"$ref": "#/$defs/compile_status"},
              "rebuild_effects": {"$ref": "#/$defs/rebuild_effects"}
            }
          }
        },
        "invariants": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/identifier"}
        }
      }
    },
    "multipole_catalog": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "role",
        "project_id",
        "family_id",
        "optimization_strategy",
        "range_policy",
        "variables",
        "invariants"
      ],
      "properties": {
        "schema_version": {"const": 1},
        "role": {"const": "project_design_variable_catalog"},
        "project_id": {"$ref": "#/$defs/identifier"},
        "family_id": {"const": "rf_multipole_ion_optics"},
        "optimization_strategy": {"const": "multipole_design_request_compilation"},
        "range_policy": {"type": "string", "minLength": 1},
        "variables": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "variable_id",
              "label",
              "kind",
              "optimization_role",
              "json_pointer",
              "unit",
              "minimum",
              "maximum",
              "compile_status",
              "rebuild_effects"
            ],
            "properties": {
              "variable_id": {"$ref": "#/$defs/identifier"},
              "label": {"type": "string", "minLength": 1},
              "kind": {"enum": ["continuous", "integer"]},
              "optimization_role": {
                "enum": ["geometry", "interface", "drive", "segmentation"]
              },
              "json_pointer": {"$ref": "#/$defs/json_pointer"},
              "unit": {"enum": ["mm", "ratio", "V", "Hz", "rad", "count"]},
              "minimum": {"type": "number"},
              "maximum": {"type": "number"},
              "compile_status": {"$ref": "#/$defs/compile_status"},
              "rebuild_effects": {"$ref": "#/$defs/rebuild_effects"}
            }
          }
        },
        "invariants": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "project_identity_locked",
              "electrode_count_equals_twice_radial_order",
              "rod_span_positive",
              "interface_nonoverlap",
              "segment_length_conservation",
              "connector_shape_supported"
            ]
          }
        }
      }
    }
  }
}
