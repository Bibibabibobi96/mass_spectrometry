{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mass-spectrometry.local/schemas/candidate_proposal.schema.json",
  "title": "Approved design candidate proposal",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "role", "candidate_id", "project_id", "request", "values"],
  "properties": {
    "schema_version": {"const": 1},
    "role": {"const": "design_candidate_proposal"},
    "candidate_id": {"$ref": "#/$defs/identifier"},
    "project_id": {"$ref": "#/$defs/identifier"},
    "request": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[A-F0-9]{64}$"}
      }
    },
    "values": {
      "type": "array", "uniqueItems": true,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["variable", "value", "unit"],
        "properties": {
          "variable": {"$ref": "#/$defs/identifier"},
          "value": {"type": "number"},
          "unit": {"type": "string", "minLength": 1}
        }
      }
    }
  },
  "$defs": {
    "identifier": {"type": "string", "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$"}
  }
}
