{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mass-spectrometry.local/schemas/execution_profiles.schema.json",
  "title": "Project execution profiles",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "role", "project_id", "profiles"],
  "properties": {
    "schema_version": {"const": 1},
    "role": {"const": "project_execution_profiles"},
    "project_id": {"$ref": "#/$defs/identifier"},
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "profile_id", "capability_id", "mode", "evidence_levels",
          "supported_operating_points", "supported_design_variables",
          "supported_constraints", "deliverable_outputs", "required_bindings",
          "steps", "limitations"
        ],
        "properties": {
          "profile_id": {"$ref": "#/$defs/identifier"},
          "capability_id": {"$ref": "#/$defs/identifier"},
          "mode": {"$ref": "#/$defs/identifier"},
          "evidence_levels": {
            "type": "array", "minItems": 1, "uniqueItems": true,
            "items": {"enum": ["plan", "static", "candidate", "formal"]}
          },
          "supported_operating_points": {
            "type": "array", "minItems": 1,
            "items": {
              "type": "object", "additionalProperties": false,
              "required": ["mass", "charge_state"],
              "properties": {
                "mass": {
                  "type": "object", "additionalProperties": false,
                  "required": ["value", "unit"],
                  "properties": {
                    "value": {"type": "number", "exclusiveMinimum": 0},
                    "unit": {"const": "Da"}
                  }
                },
                "charge_state": {"type": "integer", "not": {"const": 0}}
              }
            }
          },
          "supported_design_variables": {
            "type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/identifier"}
          },
          "supported_constraints": {
            "type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/identifier"}
          },
          "deliverable_outputs": {
            "type": "array", "uniqueItems": true,
            "items": {"enum": ["simulation_results", "comsol_model", "simion_model", "cad", "validation_report", "interface_state"]}
          },
          "required_bindings": {
            "type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/identifier"}
          },
          "steps": {
            "type": "array", "minItems": 1,
            "items": {
              "type": "object", "additionalProperties": false,
              "required": ["step_id", "kind", "shell", "entrypoint", "run_id_template", "arguments"],
              "properties": {
                "step_id": {"$ref": "#/$defs/identifier"},
                "kind": {"enum": ["gate", "run", "analyze", "package"]},
                "shell": {"enum": ["powershell", "python"]},
                "entrypoint": {"type": "string", "minLength": 1},
                "run_id_template": {"type": ["string", "null"]},
                "arguments": {"type": "array", "items": {"type": "string"}}
              }
            }
          },
          "limitations": {"type": "array", "items": {"type": "string", "minLength": 1}}
        }
      }
    }
  },
  "$defs": {
    "identifier": {"type": "string", "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$"}
  }
}
