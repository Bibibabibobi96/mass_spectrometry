{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mass-spectrometry.local/schemas/optimization_envelope.schema.json",
  "title": "Expandable project optimization envelope",
  "oneOf": [
    {"$ref": "#/$defs/oatof_envelope"},
    {"$ref": "#/$defs/multipole_envelope"}
  ],
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$"
    },
    "sha256": {"type": "string", "pattern": "^[A-F0-9]{64}$"},
    "oatof_envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "role",
        "project_id",
        "envelope_id",
        "status",
        "policy",
        "reference",
        "tof_limits"
      ],
      "properties": {
        "schema_version": {"const": 1},
        "role": {"const": "project_optimization_envelope"},
        "project_id": {"const": "oa_tof"},
        "envelope_id": {"$ref": "#/$defs/identifier"},
        "status": {"enum": ["candidate", "approved", "retired"]},
        "policy": {
          "const": "Candidates may move bidirectionally within this envelope. Exceeding it requires explicit envelope review; an approved expansion does not automatically modify the formal baseline."
        },
        "reference": {
          "type": "object",
          "additionalProperties": false,
          "required": ["baseline", "baseline_sha256"],
          "properties": {
            "baseline": {"type": "string", "minLength": 1},
            "baseline_sha256": {"$ref": "#/$defs/sha256"}
          }
        },
        "tof_limits": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "max_flight_length_mm",
            "max_positive_axial_extent_mm",
            "max_outer_radius_mm",
            "max_stage1_electrode_count",
            "max_stage2_electrode_count"
          ],
          "properties": {
            "max_flight_length_mm": {"type": "number", "exclusiveMinimum": 0},
            "max_positive_axial_extent_mm": {"type": "number", "exclusiveMinimum": 0},
            "max_outer_radius_mm": {"type": "number", "exclusiveMinimum": 0},
            "max_stage1_electrode_count": {"type": "integer", "minimum": 1},
            "max_stage2_electrode_count": {"type": "integer", "minimum": 1}
          }
        }
      }
    },
    "multipole_envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "role",
        "project_id",
        "family_id",
        "envelope_id",
        "status",
        "policy",
        "reference",
        "constraints"
      ],
      "properties": {
        "schema_version": {"const": 1},
        "role": {"const": "project_optimization_envelope"},
        "project_id": {"$ref": "#/$defs/identifier"},
        "family_id": {"const": "rf_multipole_ion_optics"},
        "envelope_id": {"$ref": "#/$defs/identifier"},
        "status": {"enum": ["candidate", "approved", "retired"]},
        "policy": {"type": "string", "minLength": 1},
        "reference": {
          "type": "object",
          "additionalProperties": false,
          "required": ["design_request", "design_request_sha256"],
          "properties": {
            "design_request": {"type": "string", "minLength": 1},
            "design_request_sha256": {"$ref": "#/$defs/sha256"}
          }
        },
        "constraints": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "constraint_id",
              "kind",
              "request_json_pointers",
              "description"
            ],
            "properties": {
              "constraint_id": {"$ref": "#/$defs/identifier"},
              "kind": {
                "enum": [
                  "immutable_identity",
                  "bounded_variable",
                  "rod_span_positive",
                  "interface_nonoverlap",
                  "segment_length_conservation",
                  "connector_compatibility"
                ]
              },
              "request_json_pointers": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "pattern": "^/(?:[^~/]|~[01])+(?:/(?:[^~/]|~[01])+)*$"
                }
              },
              "description": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    }
  }
}
