#!/bin/sh
set -eu

git diff --cached --check

blocked_files=''
while IFS= read -r path; do
  case "$path" in
    *.mph|official_docs/*.pdf|scan_*.m|tmp_*.m|*/scan_*.m|*/tmp_*.m)
      blocked_files="${blocked_files}${path}
"
      ;;
  esac
done <<EOF
$(git diff --cached --name-only --diff-filter=ACMR)
EOF

if [ -n "$blocked_files" ]; then
  echo "Commit blocked: staged files violate this repository's lifecycle rules:" >&2
  echo "$blocked_files" >&2
  echo "Document one-off work, then remove it; keep models and official PDFs outside Git." >&2
  exit 1
fi
