# COMSOL binary models are stored outside this source repository.
*.mph

# Official manuals are local reference material, not normal repository history.
official_docs/*.pdf

# Local runtime caches and machine-specific launchers are not source assets.
__pycache__/
*.py[cod]
.ruff_cache/
.pytest_cache/
.mypy_cache/
.venv/
run_comsol_mcp.cmd

# Editor backups and rejected patch remnants are disposable local files.
*.bak
*.orig
*.rej
*~

# SIMION gem2pa compiler intermediate; reproducible from the tracked GEM source.
*.processed.gem

# SIMION runtime arrays/workbenches are stored in artifacts, not source.
*.pa
*.pa#
*.pa[0-9]*
*.iob
trj*.tmp

# CAD binaries are generated into artifacts/cad.
*.sldprt
*.sldasm
*.step
*.stp

# Runtime logs belong under artifacts/runs.
*.log
